{
  "id": "sf-pi-manager",
  "name": "SF Pi Manager",
  "description": "Core manager — provides /sf-pi commands",
  "category": "core",
  "defaultEnabled": true,
  "alwaysActive": true,
  "configurable": true,
  "commands": [
    "/sf-pi",
    "/sf-pi recommended",
    "/sf-pi announcements",
    "/sf-pi skills",
    "/sf-pi doctor"
  ],
  "events": ["session_start", "session_shutdown"]
}
